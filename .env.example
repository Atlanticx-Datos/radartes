# Auth0 Configuration
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_DOMAIN=your_auth0_domain
AUTH0_TENANT_DOMAIN=your_auth0_tenant_domain
AUTH0_CUSTOM_DOMAIN=your_auth0_custom_domain
AUTH0_CALLBACK_URL=http://localhost:5001/callback

# Application Secrets
APP_SECRET_KEY=your_app_secret_key
JWT_SECRET_KEY=your_jwt_secret_key
FLASK_SECRET_KEY=your_flask_secret_key
FLASK_ENV=development

# Notion API
NOTION_TOKEN=your_notion_token
DATABASE_ID=your_database_id

# Redis/KV Store
KV_URL=your_kv_url
KV_REST_API_READ_ONLY_TOKEN=your_read_only_token
KV_REST_API_TOKEN=your_api_token
KV_REST_API_URL=your_api_url
CACHE_REFRESH_API_KEY=your_cache_refresh_key 